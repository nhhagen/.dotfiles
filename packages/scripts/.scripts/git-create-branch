#!/usr/bin/env bash

set -e

branch_input=${1}
remote=$(git remote)
remote_base=$(git remote show ${remote} | grep 'HEAD branch' | cut -d' ' -f5)
base=${2:-${remote_base}}

date=$(date "+%Y-%m-%d-%H-%M-%S")
branch=${branch_input}-${date}

echo "Creating pull request ${branch} from ${base}"

git switch $base
git pull --rebase
git checkout -b $branch
git push --set-upstream origin $branch
